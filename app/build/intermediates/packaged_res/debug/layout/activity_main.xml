<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:padding="24dp"
    android:gravity="center_horizontal">

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="hcompress" android:textSize="28sp" android:textStyle="bold"
        android:textColor="?attr/colorPrimary" android:layout_marginBottom="4dp"/>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Canonical Huffman 压缩工具" android:textSize="14sp"
        android:textColor="?android:attr/textColorSecondary" android:layout_marginBottom="24dp"/>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginBottom="16dp" style="@style/Widget.Material3.CardView.Elevated">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">

            <TextView android:id="@+id/tv_file_name" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="未选择文件"
                android:textSize="16sp" android:layout_marginBottom="8dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_pick_file" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:text="选择文件"
                style="@style/Widget.Material3.Button.OutlinedButton"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_compress" android:layout_width="0dp"
            android:layout_weight="1" android:layout_height="wrap_content"
            android:text="压缩" android:layout_marginEnd="8dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_decompress" android:layout_width="0dp"
            android:layout_weight="1" android:layout_height="wrap_content"
            android:text="解压" style="@style/Widget.Material3.Button.TonalButton"/>
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_plugins" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:text="插件商店"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_marginTop="16dp"/>

</LinearLayout>
